# Copy this file to `.env` and fill in the values. All keys are optional —
# leaving a section blank simply disables that feature locally.

# --- Google Analytics 4 ------------------------------------------------------
# Analytics only loads in the browser after the visitor accepts cookies.
# Leave empty to disable analytics entirely (e.g. local development).
VITE_GA_MEASUREMENT_ID=

# --- Supabase ----------------------------------------------------------------
# Project URL and public anon key from: Supabase dashboard → Project Settings →
# API. The anon key is safe to expose in the browser; data access is enforced
# by Row-Level Security (see supabase/schema.sql). Leave empty to fall back to
# static data and disable the contact form's backend.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# --- Error reporting (Sentry) ------------------------------------------------
# DSN from: Sentry dashboard → Project → Settings → Client Keys (DSN). When set,
# warnings/errors logged via src/lib/logger.ts are forwarded to Sentry in
# production builds. Leave empty to disable reporting (the SDK is never loaded).
VITE_SENTRY_DSN=

# --- Bot protection: Cloudflare Turnstile ------------------------------------
# Public SITE key from: Cloudflare dashboard → Turnstile → add a widget. When
# set, the contact + testimonial forms render a Turnstile challenge and submit
# through the `submit` Supabase Edge Function, which verifies the token with the
# matching SECRET key. The secret is NOT a VITE_ var — set it on the function:
#   supabase secrets set TURNSTILE_SECRET_KEY=your-secret-key
# Leave empty to disable the challenge (forms fall back to the direct path).
VITE_TURNSTILE_SITE_KEY=

# --- Email notifications (Resend) — server-side only -------------------------
# These are NOT VITE_ vars: they're secrets on the `submit` Edge Function, set
# with the CLI, never exposed to the browser. With them unset, the function
# simply doesn't send mail (submissions still save). See supabase/README.md §6:
#   supabase secrets set RESEND_API_KEY=re_xxx
#   supabase secrets set CONTACT_FROM="Navya EdTech <hello@your-domain.com>"
#   supabase secrets set CONTACT_NOTIFY_TO=team@your-domain.com
